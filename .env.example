# Groq API key (same as GarminBot)
GROQ_API_KEY=your_groq_api_key_here

# Absolute path to local Obsidian vault clone
# Local (Windows dev): C:/DEV/Obsidian/Nelson
# Hetzner: /home/garminbot/Obsidian
OBSIDIAN_VAULT_PATH=/home/garminbot/Obsidian

# GitHub PAT with repo write scope (for pushing notes to Obsidian repo)
GITHUB_TOKEN=your_github_pat_here
